# ZamAI Pro Models Environment Configuration
# Copy this file to .env and fill in your values

# Hugging Face Configuration
HUGGINGFACE_TOKEN=your_hf_token_here
HF_HOME=./cache/huggingface
HF_DATASETS_CACHE=./cache/datasets

# API Configuration  
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Gradio Configuration
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false
GRADIO_AUTH=false

# Model Configuration
MODEL_CACHE_DIR=./cache/transformers
DEFAULT_CHAT_MODEL=mistralai/Mistral-7B-Instruct-v0.3
DEFAULT_WHISPER_MODEL=openai/whisper-large-v3
DEFAULT_PHI_MODEL=microsoft/Phi-3-mini-4k-instruct
DEFAULT_EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Performance Settings
MAX_CONCURRENT_REQUESTS=10
MODEL_LOADING_TIMEOUT=300
REQUEST_TIMEOUT=120
BATCH_SIZE=4

# Redis Configuration (for Docker deployment)
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Database Configuration (if needed)
DATABASE_URL=sqlite:///./zamai.db

# Development/Production
ENVIRONMENT=development
DEBUG=true
TESTING=false

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_ROTATION=midnight
LOG_RETENTION=30

# Security
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here
ALLOWED_HOSTS=localhost,127.0.0.1,zamai.local
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# SSL Configuration
SSL_CERT_FILE=./ssl/cert.pem
SSL_KEY_FILE=./ssl/key.pem
SSL_ENABLED=false

# Monitoring
WANDB_PROJECT=zamai-pro-models
WANDB_ENTITY=your-wandb-entity
ENABLE_METRICS=true
METRICS_PORT=9090

# Advanced Model Settings
TORCH_DEVICE=auto
TORCH_DTYPE=float16
USE_FLASH_ATTENTION=true
MODEL_PARALLEL=false
QUANTIZATION=none

# Voice Assistant Specific
WHISPER_LANGUAGE=auto
WHISPER_TASK=transcribe
WHISPER_TEMPERATURE=0.0
WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4

# Text Generation Settings
GENERATION_MAX_TOKENS=500
GENERATION_TEMPERATURE=0.7
GENERATION_TOP_P=0.9
GENERATION_TOP_K=50
GENERATION_REPETITION_PENALTY=1.1

# File Upload Settings
MAX_FILE_SIZE=100MB
ALLOWED_EXTENSIONS=wav,mp3,m4a,flac,ogg,txt,pdf,docx

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# Background Tasks
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
