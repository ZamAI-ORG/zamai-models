{
  "model_name": "tasal9/zamai-qa-pashto",
  "base_model": "deepset/roberta-base-squad2",
  "task": "question_answering",
  "description": "Pashto question answering model",
  "training_params": {
    "learning_rate": 2e-05,
    "batch_size": 4,
    "num_epochs": 3,
    "max_length": 512,
    "use_lora": true,
    "lora_r": 16,
    "lora_alpha": 32
  },
  "dataset": {
    "train_file": "data/pashto_training_data.json",
    "validation_split": 0.1
  }
}